# P2P Agent Mesh — SNIN DAO Pilot (.env)
# Использование: docker-compose --env-file snin.env up -d

# === Агенты ===
AGENT_NAME=echo_agent
AGENT_CAP=echo
AGENT_PORT=0
AGENT_LISTEN=1

# === Relay (локальный или внешний) ===
# Для локального: оставить RELAY_HOST=relay (имя сервиса в compose)
# Для внешнего: RELAY_HOST=relay-mesh.v2.site, RELAY_PORT=8443
RELAY_HOST=relay
RELAY_PORT=8443

# === Безопасность ===
MESH_TLS=1

# === Relay лимиты (только для локального relay) ===
RELAY_MAX_MSGS_PER_SEC=10
RELAY_MAX_CONN_PER_IP=5
RELAY_MAX_PAYLOAD=1048576

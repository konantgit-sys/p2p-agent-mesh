# Relay Server — Configuration
# Copy to .env and adjust for your deployment

# Rate limiting
RELAY_MAX_MSGS_PER_SEC=10      # Max messages per second from one agent (default)
RELAY_MAX_CONN_PER_IP=5        # Max concurrent connections from one IP
RELAY_MAX_PAYLOAD=1048576      # Max payload size in bytes (1 MB)

# Server
RELAY_PORT=9900                # TCP port
RELAY_HOST=0.0.0.0             # Bind address

# Optional: relay identity key (ed25519 hex)
# If not set, a new identity is generated on every start
# RELAY_PRIVATE_KEY=...
